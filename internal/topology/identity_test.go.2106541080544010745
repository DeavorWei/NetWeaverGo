//go:build legacy
// +build legacy

package topology

import (
	"testing"

	"github.com/NetWeaverGo/core/internal/models"
)

func TestIdentityResolverPriorityAndConflict(t *testing.T) {
	resolver := NewIdentityResolver([]models.DiscoveryDevice{
		{DeviceIP: "1.1.1.1", MgmtIP: "10.0.0.1", ChassisID: "00e0-fc00-0001", NormalizedName: "CORE1"},
		{DeviceIP: "1.1.1.2", MgmtIP: "10.0.0.2", ChassisID: "00e0-fc00-0002", NormalizedName: "CORE2"},
		{DeviceIP: "1.1.1.3", MgmtIP: "10.0.0.3", ChassisID: "00e0-fc00-0003", NormalizedName: "CORE1"},
		{DeviceIP: "1.1.1.4", MgmtIP: "10.0.0.4", SerialNumber: "SN-0001", NormalizedName: "DIST1"},
	})

	deviceID, conflict, _ := resolver.Resolve("", "10.0.0.1", "", "core2")
	if deviceID != "1.1.1.1" {
		t.Fatalf("expected mgmtIP to win, got %s", deviceID)
	}
	if !conflict {
		t.Fatalf("expected multi-identifier conflict for mismatched name")
	}

	deviceID, conflict, candidates := resolver.Resolve("", "", "", "core1")
	if deviceID != "1.1.1.1" {
		t.Fatalf("expected first candidate for duplicated name, got %s", deviceID)
	}
	if !conflict {
		t.Fatalf("expected conflict when name resolves to multiple devices")
	}
	if len(candidates) < 2 {
		t.Fatalf("expected duplicated name candidates, got %v", candidates)
	}

	deviceID, conflict, _ = resolver.Resolve("SN-0001", "10.0.0.1", "", "")
	if deviceID != "1.1.1.4" {
		t.Fatalf("expected serial to win, got %s", deviceID)
	}
	if !conflict {
		t.Fatalf("expected conflict when lower-priority identifier points to another device")
	}
}
