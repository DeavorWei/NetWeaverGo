func newTopologyTestBuilder(t *testing.T) (*Builder, *gorm.DB) {
	t.Helper()

	db, err := gorm.Open(sqlite.Open(":memory:"), &gorm.Config{})
	if err != nil {
		t.Fatalf("open db failed: %v", err)
	}

	if err := db.AutoMigrate(
		&models.DiscoveryDevice{},
		&models.TopologyInterface{},
		&models.TopologyLLDPNeighbor{},
		&models.TopologyFDBEntry{},
		&models.TopologyARPEntry{},
		&models.TopologyAggregateGroup{},
		&models.TopologyAggregateMember{},
		&models.TopologyEdge{},
	); err != nil {
		t.Fatalf("migrate failed: %v", err)
	}

	return NewBuilder(db), db
}

func TestBuildIntegrationDualSwitchConfirmed(t *testing.T) {
	builder, db := newTopologyTestBuilder(t)
	taskID := "task_confirmed"

	devices := []models.DiscoveryDevice{
		{TaskID: taskID, DeviceIP: "10.0.0.1", MgmtIP: "10.0.0.1", Hostname: "SW1", NormalizedName: "SW1", Status: "success"},
		{TaskID: taskID, DeviceIP: "10.0.0.2", MgmtIP: "10.0.0.2", Hostname: "SW2", NormalizedName: "SW2", Status: "success"},
	}
	if err := db.Create(&devices).Error; err != nil {
		t.Fatalf("create devices failed: %v", err)
	}

	neighbors := []models.TopologyLLDPNeighbor{
		{TaskID: taskID, DeviceIP: "10.0.0.1", LocalInterface: "GE1/0/1", NeighborName: "SW2", NeighborPort: "GE1/0/24", NeighborIP: "10.0.0.2"},
		{TaskID: taskID, DeviceIP: "10.0.0.2", LocalInterface: "GE1/0/24", NeighborName: "SW1", NeighborPort: "GE1/0/1", NeighborIP: "10.0.0.1"},
	}
	if err := db.Create(&neighbors).Error; err != nil {
		t.Fatalf("create neighbors failed: %v", err)
	}

	result, err := builder.Build(taskID)
	if err != nil {
		t.Fatalf("build failed: %v", err)
	}
	if result.ConfirmedEdges < 1 {
		t.Fatalf("expected at least one confirmed edge, got %+v", result)
	}

	var edges []models.TopologyEdge
	if err := db.Where("task_id = ?", taskID).Find(&edges).Error; err != nil {
		t.Fatalf("load edges failed: %v", err)
	}

	found := false
	for _, edge := range edges {
		if edge.EdgeType == "physical" && edge.Status == "confirmed" &&
			((edge.ADeviceID == "10.0.0.1" && edge.BDeviceID == "10.0.0.2") ||
				(edge.ADeviceID == "10.0.0.2" && edge.BDeviceID == "10.0.0.1")) {
			found = true
			break
		}
	}
	if !found {
		t.Fatalf("expected confirmed physical edge between switches, got %+v", edges)
	}
}

