func TestBuildIntegrationMultiPeerConflict(t *testing.T) {
	builder, db := newTopologyTestBuilder(t)
	taskID := "task_conflict"

	devices := []models.DiscoveryDevice{
		{TaskID: taskID, DeviceIP: "10.0.3.1", MgmtIP: "10.0.3.1", Hostname: "ACCESS1", NormalizedName: "ACCESS1", Status: "success"},
		{TaskID: taskID, DeviceIP: "10.0.3.2", MgmtIP: "10.0.3.2", Hostname: "UP1", NormalizedName: "UP1", Status: "success"},
		{TaskID: taskID, DeviceIP: "10.0.3.3", MgmtIP: "10.0.3.3", Hostname: "UP2", NormalizedName: "UP2", Status: "success"},
	}
	if err := db.Create(&devices).Error; err != nil {
		t.Fatalf("create devices failed: %v", err)
	}

	neighbors := []models.TopologyLLDPNeighbor{
		{TaskID: taskID, DeviceIP: "10.0.3.1", LocalInterface: "GE1/0/1", NeighborName: "UP1", NeighborPort: "GE1/0/24", NeighborIP: "10.0.3.2"},
		{TaskID: taskID, DeviceIP: "10.0.3.1", LocalInterface: "GE1/0/1", NeighborName: "UP2", NeighborPort: "GE1/0/24", NeighborIP: "10.0.3.3"},
	}
	if err := db.Create(&neighbors).Error; err != nil {
		t.Fatalf("create neighbors failed: %v", err)
	}

	if _, err := builder.Build(taskID); err != nil {
		t.Fatalf("build failed: %v", err)
	}

	var edges []models.TopologyEdge
	if err := db.Where("task_id = ?", taskID).Find(&edges).Error; err != nil {
		t.Fatalf("load edges failed: %v", err)
	}

	conflictCount := 0
	for _, edge := range edges {
		if edge.ADeviceID == "10.0.3.1" && edge.AIf == "GE1/0/1" &&
			edge.Status == "conflict" && contains(edge.DiscoveryMethods, "multi_peer_conflict") {
			conflictCount++
		}
	}
	if conflictCount < 2 {
		t.Fatalf("expected both edges to be marked conflict, got %+v", edges)
	}
}

func contains(items []string, target string) bool {
	for _, item := range items {
		if item == target {
			return true
		}
	}
	return false
}
