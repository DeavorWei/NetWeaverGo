	var edges []models.TopologyEdge
	if err := db.Where("task_id = ?", taskID).Find(&edges).Error; err != nil {
		t.Fatalf("load edges failed: %v", err)
	}

	found := false
	for _, edge := range edges {
		if edge.EdgeType == "logical_aggregate" && edge.Status == "confirmed" &&
			edge.LogicalAIf != "" && edge.LogicalBIf != "" &&
			contains(edge.DiscoveryMethods, "aggregate_merge") {
			found = true
			break
		}
	}
	if !found {
		t.Fatalf("expected confirmed logical_aggregate edge with aggregate_merge method, got %+v", edges)
	}
