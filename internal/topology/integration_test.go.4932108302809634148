	groups := []models.TopologyAggregateGroup{
		{TaskID: taskID, DeviceIP: "10.0.1.1", AggregateName: "Trunk10", Mode: "lacp"},
		{TaskID: taskID, DeviceIP: "10.0.1.2", AggregateName: "Trunk20", Mode: "lacp"},
