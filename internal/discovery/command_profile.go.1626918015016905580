package discovery

import (
	"fmt"
	"time"

	"github.com/NetWeaverGo/core/internal/config"
	"github.com/NetWeaverGo/core/internal/executor"
)

// DefaultVendor 默认厂商
const DefaultVendor = "huawei"

// SupportedVendors 支持的厂商列表
var SupportedVendors = []string{"huawei", "h3c", "cisco"}

// IsVendorSupported 检查厂商是否支持
func IsVendorSupported(vendor string) bool {
	for _, v := range SupportedVendors {
		if v == vendor {
			return true
		}
	}
	return false
}

// BuildDiscoveryPlan 根据设备画像构建设备发现计划
// 这是 discovery 与 executor 配置统一的唯一入口
func BuildDiscoveryPlan(profile *config.DeviceProfile, taskTimeout time.Duration) executor.ExecutionPlan {
	if profile == nil {
		profile = config.GetDeviceProfile("huawei")
	}

	commands := make([]executor.PlannedCommand, len(profile.Commands))
	for i, cmd := range profile.Commands {
		timeout := time.Duration(cmd.TimeoutSec) * time.Second
		if timeout == 0 {
			timeout = taskTimeout
		}
		// 裁剪超时不超过任务级上限
		if taskTimeout > 0 && timeout > taskTimeout {
			timeout = taskTimeout
		}

		commands[i] = executor.PlannedCommand{
			Key:             cmd.CommandKey,
			Command:         cmd.Command,
			Timeout:         timeout,
			ContinueOnError: true,
		}
	}

	return executor.ExecutionPlan{
		Name:                  fmt.Sprintf("discovery-%s", profile.Vendor),
		Commands:              commands,
		AbortOnTransportErr:   true,
		AbortOnCommandTimeout: false,
		ContinueOnCmdError:    true,
		Mode:                  executor.PlanModeDiscovery,
	}
}

// GetCommandByKey 根据命令键获取命令规格
// 从 config.DeviceProfile 查找
func GetCommandByKey(vendor, commandKey string) *config.CommandSpec {
	profile := config.GetDeviceProfile(vendor)
	for i := range profile.Commands {
		if profile.Commands[i].CommandKey == commandKey {
			return &profile.Commands[i]
		}
	}
	return nil
}
